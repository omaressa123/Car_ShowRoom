graph TB
    subgraph "Client Tier (Frontend)"
        UI["Web Browser (HTML/CSS/JS)"]
    end

    subgraph "Web Tier (Spring Boot Controllers)"
        AuthCtrl["AuthController"]
        CarCtrl["CarsController"]
        ContractCtrl["ContractsController"]
        AdminCtrl["AdminContractsController"]
        DashCtrl["DashboardController"]
    end

    subgraph "Service Tier (Business Logic)"
        AuthSvc["AuthService"]
        CarSvc["CarService"]
        ContractSvc["ContractService"]
        DashSvc["DashboardService"]
        AuditSvc["AuditService"]
        Security["Spring Security / JWT"]
    end

    subgraph "Data Tier (Persistence)"
        Repo["JPA Repositories"]
        DB[(MySQL Database)]
    end

    %% Dependencies
    UI -- "REST API (HTTP/JSON)" --> AuthCtrl
    UI -- "REST API (HTTP/JSON)" --> CarCtrl
    UI -- "REST API (HTTP/JSON)" --> ContractCtrl
    UI -- "REST API (HTTP/JSON)" --> DashCtrl

    AuthCtrl --> AuthSvc
    CarCtrl --> CarSvc
    ContractCtrl --> ContractSvc
    AdminCtrl --> ContractSvc
    DashCtrl --> DashSvc

    AuthSvc --> Repo
    CarSvc --> Repo
    ContractSvc --> Repo
    DashSvc --> Repo
    
    AuthSvc --> AuditSvc
    CarSvc --> AuditSvc
    ContractSvc --> AuditSvc

    AuthSvc --> Security
    Security --> Repo

    Repo -- "JDBC/Hibernate" --> DB

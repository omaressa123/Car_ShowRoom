graph TB
    subgraph "Client Tier"
        Browser["User's Web Browser"]
    end

    subgraph "Server Tier (Docker Host / Cloud Server)"
        subgraph "Application Container (car-showroom-app)"
            App["Spring Boot Application (JAR)"]
        end

        subgraph "Database Container (car-showroom-db)"
            DB["MySQL 8.0 Server"]
            Storage[("Persistent Volume: mysql_data")]
        end
    end

    %% Network Connections
    Browser -- "HTTP (Port 8080)" --> App
    App -- "JDBC (Port 3306)" --> DB
    DB -- "Mount" --> Storage
